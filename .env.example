# Copia questo file in ".env" e completa i valori PRIMA di eseguire
# "npm run build:mobile". Senza queste variabili l'app compilata si blocca
# all'avvio con l'errore "Missing Supabase environment variables".
#
# I valori si trovano nella dashboard Supabase del progetto:
# Project Settings -> API

# URL del progetto (dedotto dal project_id in supabase/config.toml)
VITE_SUPABASE_URL=https://dtvemuokskozikvihzjt.supabase.co

# Chiave pubblica ("publishable" / "anon public") del progetto
VITE_SUPABASE_PUBLISHABLE_KEY=INSERISCI_LA_TUA_CHIAVE_QUI
